# Agent X OSS - Environment Variables
# Copy this file: cp .env.example .env (Mac/Linux) | copy .env.example .env (Windows)
# Then fill in your values. Never commit the .env file.

# -----------------------------------------
# REQUIRED: Anthropic API Key (default LLM)
# Get yours at https://console.anthropic.com
# -----------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------
# REQUIRED: X (Twitter) credentials
# Used by browser-use to authenticate and scrape your timeline
# -----------------------------------------
X_USERNAME=your_x_username_or_email
X_PASSWORD=your_x_password

# -----------------------------------------
# OPTIONAL: Override the default LLM model
# Default is anthropic/claude-sonnet-4-20250514
# To use OpenAI instead: openai/gpt-4.1-mini (requires OPENAI_API_KEY below)
# -----------------------------------------
# LLM_MODEL=anthropic/claude-sonnet-4-20250514

# -----------------------------------------
# OPTIONAL: OpenAI API Key
# Only needed if you set LLM_MODEL to an openai/ model above
# -----------------------------------------
# OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------------------
# OPTIONAL: App settings
# -----------------------------------------
MEMORY_PATH=./MEMORY.md
DB_PATH=./db/agent_x.db
HEADLESS_BROWSER=true
MAX_TWEETS_PER_RUN=15
